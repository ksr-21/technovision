rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public writes for registration
    // In a production app, you might want to add validation or use Firebase Auth
    match /registrations/{registration} {
      allow create: if true;
      allow read: if false; // Only admin should read, but we're using a simple password check on client
    }

    // For the Admin Panel to work with the current "simple password" implementation,
    // the rules would technically need to allow read access.
    // WARNING: This is insecure for PII data.
    // In a real app, you MUST use Firebase Auth and check request.auth.token.admin == true
    match /registrations/{registration} {
      allow read: if true;
    }
  }
}
